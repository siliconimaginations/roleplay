# Copy this file to .env and fill in your API keys.
# .env is gitignored — never commit real keys.
#
# roleplay reads this file automatically when you run:
#   python -m roleplay.poc --config scenarios/example.toml
# or pass a custom path:
#   python -m roleplay.poc --config scenarios/example.toml --env-file /path/to/keys.env
#
# Real environment variables always take precedence over this file.

# Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic API key — get one at https://console.anthropic.com/
# Only needed if provider = "claude" in your scenario TOML
ANTHROPIC_API_KEY=your-anthropic-api-key-here
